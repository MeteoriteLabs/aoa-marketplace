{
  "name": "@armyofagents/aoa-marketplace-builder",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "aggregate": "tsx src/aggregate.ts",
    "validate": "tsx src/aggregate.ts --validate-only",
    "publish-cdn": "tsx src/publish.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "pnpm aggregate && pnpm validate"
  },
  "dependencies": {
    "isomorphic-git": "^1.27.0",
    "semver": "^7.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/semver": "^7.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
